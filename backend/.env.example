# PostgreSQL connection string used by Prisma and the backend.
# Matches the credentials defined in the root docker-compose.yml `db` service.
# Host port is 5433 to avoid clashing with a default local Postgres on 5432.
DATABASE_URL="postgresql://flowforge:flowforge@localhost:5433/flowforge?schema=public"

# HTTP port the API listens on.
PORT=3000

# Secret used to sign JWT access tokens. Use a long random value in production.
JWT_SECRET="dev-only-secret-change-me"
# Access-token lifetime (vercel/ms format, e.g. "15m", "1h").
JWT_EXPIRES_IN="1h"

# Groq API key for the AI failure-analysis feature (requirement G).
# Optional: without it the analysis endpoint answers 503 and everything else works.
GROQ_API_KEY=""
# Groq model used for analysis (Llama 3.3 70B — fast and reliable on the free tier).
GROQ_MODEL="llama-3.3-70b-versatile"
